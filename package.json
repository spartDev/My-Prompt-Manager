{
  "name": "prompt-library-extension",
  "version": "1.9.0",
  "description": "Chrome extension for managing personal prompt library",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "package": "node package-extension.cjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "prepare": "if [ \"$CI\" = \"true\" ] || [ -n \"$GITHUB_ACTIONS\" ] || [ -n \"$JENKINS_URL\" ] || [ -n \"$BUILDKITE\" ]; then echo 'CI detected, skipping husky'; else husky; fi",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@crxjs/vite-plugin": "2.4.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "4.1.18",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/chrome": "0.1.42",
    "@types/jsdom": "27.0.0",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "4.0.18",
    "happy-dom": "20.9.0",
    "husky": "9.1.7",
    "jsdom": "28.0.0",
    "lint-staged": "16.2.7",
    "playwright": "1.58.2",
    "postcss": "8.5.14",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "vite": "7.3.3",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@floating-ui/dom": "1.7.5",
    "dompurify": "3.4.3",
    "lz-string": "1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.7.0",
    "uuid": "13.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "biome lint --write --no-errors-on-unmatched"
  },
  "overrides": {
    "@crxjs/vite-plugin": {
      "rollup": "2.80.0"
    }
  }
}
